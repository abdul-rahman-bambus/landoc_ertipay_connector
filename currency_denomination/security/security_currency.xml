<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Category -->
        <record id="currency_category" model="ir.module.category">
            <field name="name">Currency Category</field>
            <field name="sequence">1</field>
        </record>

        <!-- Group: User -->
        <record id="group_currency_user" model="res.groups">
            <field name="name">Currency User</field>
            <field name="category_id" ref="currency_denomination.currency_category"/>
        </record>

        <!-- Group: Manager -->
        <record id="group_currency_manager" model="res.groups">
            <field name="name">Currency Manager</field>
            <field name="category_id" ref="currency_denomination.currency_category"/>
            <field name="implied_ids" eval="[(4, ref('group_currency_user'))]"/>
        </record>

    </data>
</odoo>

