<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- This cron job automatically validates WhatsApp templates every 2 minutes -->
        <record id="auto_validate_whatsapp_template" model="ir.cron">
            <field name="name">Auto Validate Whatsapp Template</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">2</field>
            <field name="interval_type">minutes</field>
            <field name="model_id" ref="whatsapp_business.model_template_whatsapp"/>
            <field name="code">model.meta_temp_status_update()</field>
            <field name="state">code</field>
        </record>
    </data>
</odoo>
