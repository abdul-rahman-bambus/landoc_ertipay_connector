<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Category -->
        <record id="whatsapp_business_category" model="ir.module.category">
            <field name="name">Whatsapp Business</field>
            <field name="sequence">1</field>
        </record>

        <!-- Group: User -->
        <record id="group_whatsapp_business_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="whatsapp_business.whatsapp_business_category"/>
        </record>

        <!-- Group: Manager -->
        <record id="group_whatsapp_business_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="whatsapp_business.whatsapp_business_category"/>
            <field name="implied_ids" eval="[(4, ref('group_whatsapp_business_user'))]"/>
        </record>

    </data>
</odoo>

