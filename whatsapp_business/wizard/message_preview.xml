<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- WH: Preview   -->
    <record id="message_preview_view_form" model="ir.ui.view">
        <field name="name">message.preview.view.form</field>
        <field name="model">message.preview</field>
        <field name="arch" type="xml">
            <form string="Preview Message">
                <sheet>
                    <group>
                        <group>
                            <field name="no_record" invisible="1"/>
                            <field name="template_id" invisible="1"/>
                            <field name="test_record" invisible="1"/>
                            <label for="test_record" string="Test Record: "/>
                            <field name="test_record" nolabel="1"
                                   options="{'hide_model': True, 'no_create': True, 'no_open': True}"
                                   readonly="False" invisible="no_record"/>
                            <b invisible="not no_record" class="text-danger">No record for this model</b>

                        </group>
                    </group>
                    <div colspan="2">
                        <field name="preview_whatsapp" no_label="1"/>
                    </div>
                </sheet>
                <footer>
                    <button name="cancel" special="cancel" data-hotkey="z" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action   -->
    <record id="message_preview_action_from_template" model="ir.actions.act_window">
        <field name="name">Template Preview</field>
        <field name="res_model">message.preview</field>
        <field name="binding_model_id" eval="False"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="message_preview_view_form"/>
        <field name="target">new</field>
        <field name="context">{'default_template_id': active_id}</field>
    </record>
</odoo>
