<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- WH: Preview   -->
    <record id="chatter_preview_view_form" model="ir.ui.view">
        <field name="name">chatter.preview.view.form</field>
        <field name="model">chatter.preview</field>
        <field name="arch" type="xml">
            <form string="Preview Message">
                <sheet>
                    <group>
                        <group>
                            <field name="selected_template_ids" widget="many2many_tags" readonly="1" invisible="1"/>
                            <field name="model" invisible="1"/>
                            <field name="active_id" invisible="1"/>
                            <field name="template_id" invisible="0"/>
                            <field name="current_record" invisible="1"/>
                            <label for="current_record" string=" "/>
                            <b invisible="selected_template_ids" class="text-danger">There is no meta approved template
                                for this
                                model
                            </b>

                        </group>
                        <group>
                            <field name="preview_whatsapp" no_label="1"/>
                        </group>
                    </group>

                </sheet>
                <footer>
                    <button name="send_whatsapp_message" type="object" data-hotkey="s" string="Send Message"
                            class="btn-secondary"/>
                    <button name="cancel" special="cancel" data-hotkey="z" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action   -->
    <record id="chatter_preview_action_from_chatter" model="ir.actions.act_window">
        <field name="name">Template Preview</field>
        <field name="res_model">chatter.preview</field>
        <field name="binding_model_id" eval="False"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="chatter_preview_view_form"/>
        <field name="target">new</field>
    </record>
</odoo>
