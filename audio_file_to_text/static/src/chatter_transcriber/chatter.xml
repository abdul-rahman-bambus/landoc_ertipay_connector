<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="MailChatterInherit" t-inherit="mail.Chatter" t-inherit-mode="extension">
        <xpath expr="//button[hasclass('o-mail-Chatter-activity')]" position="after">
            <button t-if="props.has_activities" class="o-mail-Chatter-audio-transcribe btn btn-secondary text-nowrap ms-1" t-att-class="{ 'my-2': !props.compactHeight }" data-hotkey="shift+t" t-on-click="openTranscriber">
                <span>Audio Transcribe</span>
            </button>
        </xpath>
    </t>
</templates>
