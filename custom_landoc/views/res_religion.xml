<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <!-- Religion Form View -->
    <record id="view_religion_form" model="ir.ui.view">
        <field name="name">res.religion.form</field>
        <field name="model">res.religion</field>
        <field name="arch" type="xml">
            <form string="Religion">
                <sheet>
                    <group>                
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="code"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Religion Tree/List View -->
    <record id="view_religion_list" model="ir.ui.view">
        <field name="name">res.religion.list</field>
        <field name="model">res.religion</field>
        <field name="arch" type="xml">
            <list string="Religions">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <!-- Action to open Religion Menu -->
    <record id="action_religion" model="ir.actions.act_window">
        <field name="name">Religions</field>
        <field name="res_model">res.religion</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_religion"
              name="Religions"
              parent="master_data_main_menu" groups="custom_landoc.group_landoc_manager"
              action="action_religion"/>
    </data>
</odoo>

