<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- User Menu Restrictions   -->
    <!--
        This menu item's purpose is to overwrite another one defined in
        the base module in order to set new groups.
    -->
    <menuitem
            id="crm.crm_menu_root"
            name="CRM"
            web_icon="crm,static/description/icon.png"
            groups="sales_team.group_sale_salesman,sales_team.group_sale_manager,custom_landoc.group_landoc_manager,custom_landoc.group_landoc_legal_user,custom_landoc.group_landoc_legal_team_lead_user,custom_landoc.group_landoc_user,custom_landoc.group_landoc_crm_team_lead_user,custom_landoc.group_landoc_external_user,custom_landoc.group_landoc_external_team_lead_user,custom_landoc.group_landoc_internal_user,custom_landoc.group_landoc_internal_team_lead_user,custom_landoc.group_landoc_accounting_user,custom_landoc.group_landoc_accounting_team_lead_user,custom_landoc.group_landoc_marketing_user,custom_landoc.group_landoc_marketing_team_lead_user"
            sequence="25"/>


    <!--  Contacts  -->
    <record id="crm.res_partner_menu_customer" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('custom_landoc.group_landoc_manager'),ref('custom_landoc.group_landoc_user'),ref('custom_landoc.group_landoc_crm_team_lead_user')])]"/>
    </record>
    <menuitem name="Contacts"
              id="contacts.menu_contacts"
              sequence="20"
              web_icon="contacts,static/description/icon.png"
              groups="custom_landoc.group_landoc_manager,custom_landoc.group_landoc_user,custom_landoc.group_landoc_crm_team_lead_user"/>

    <menuitem id="contacts.res_partner_menu_contacts"
              name="Contacts"
              action="contacts.action_contacts"
              parent="contacts.menu_contacts"
              sequence="2"
              groups="custom_landoc.group_landoc_manager,custom_landoc.group_landoc_user,custom_landoc.group_landoc_crm_team_lead_user"/>

    <!--  Accounting  -->
    <record id="account.menu_finance" model="ir.ui.menu">
        <field name="groups_id"
               eval="[(6, 0, [ref('account.group_account_manager'),ref('custom_landoc.group_landoc_accounting_user'),ref('custom_landoc.group_landoc_accounting_team_lead_user')])]"/>
    </record>

    <!--  Employee  -->
    <record id="hr.menu_hr_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('hr.group_hr_manager')])]"/>
    </record>

    <!-- My Quotations  -->
    <record id="sale_crm.sale_order_menu_quotations_crm" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('custom_landoc.group_landoc_manager'),ref('custom_landoc.group_landoc_user'),ref('custom_landoc.group_landoc_crm_team_lead_user')])]"/>
    </record>

    <!-- Expenses  -->
    <record id="hr_expense.menu_hr_expense_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('custom_landoc.group_landoc_manager'),ref('custom_landoc.group_landoc_manager')])]"/>
    </record>

    <!-- Purchase  -->
    <record id="purchase.menu_purchase_root" model="ir.ui.menu">
        <field name="groups_id"
               eval="[(6, 0, [ref('custom_landoc.group_landoc_manager'),ref('custom_landoc.group_landoc_accounting_user'),ref('custom_landoc.group_landoc_accounting_team_lead_user')])]"/>
    </record>


</odoo>
