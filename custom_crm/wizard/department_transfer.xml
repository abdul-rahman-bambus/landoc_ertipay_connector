<?xml version="1.0"?>
<odoo>
        <record id="crm_department_transfer_view_form" model="ir.ui.view">
            <field name="name">crm.department.transfer.form</field>
            <field name="model">crm.department.transfer</field>
            <field name="arch" type="xml">
                <form string="Department Transfer">
                    <field name="lead_ids" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <group>
                        <field name="team_id" options="{'no_create_edit': True}" />
                        <field name="feedback" required="1"/>
                    </group>
                    <footer>
                        <button name="action_department_transfer" string="Transfer" type="object" class="btn-primary" data-hotkey="q"/>
                        <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="crm_department_transfer_action" model="ir.actions.act_window">
            <field name="name">Department Transfer</field>
            <field name="res_model">crm.department.transfer</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="crm_department_transfer_view_form"/>
            <field name="target">new</field>
            <field name="binding_model_id" ref="crm.model_crm_lead"/>
            <field name="context">{
                'dialog_size' : 'medium',
                'default_lead_ids': active_ids,
            }</field>
        </record>
</odoo>
