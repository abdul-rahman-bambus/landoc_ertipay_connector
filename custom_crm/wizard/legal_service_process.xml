<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="legal_service_process_wiz_form" model="ir.ui.view">
            <field name="name">legal.service.process.wiz.form</field>
            <field name="model">legal.service.process</field>
            <field name="arch" type="xml">
                <form string="Legal Service">
                    <sheet>
                        <group>
                            <group>
                                <field name="service_category_id" invisible="1" readonly="1"/>
                                <field name="workflow_master_id" invisible="1"/>
                                <field name="is_ec" invisible="1"/>
                                <field name="service_id" readonly="1"/>
                                <field name="is_ec_apply" invisible="is_ec"/>
                            </group>
                            <group>
                                <field name="lead_id" invisible="1" readonly="1"/>
                            </group>
                            <group>
                                <field name="ec_start_date" invisible="not is_ec_apply" required="is_ec_apply"/>
                            </group>
                            <group>
                                <field name="ec_end_date" invisible="not is_ec_apply" required="is_ec_apply"/>
                                <field name="ec_end_date_warning" string=" " class="text-danger"
                                       invisible="not ec_end_date_warning" readonly="1"/>
                            </group>
                        </group>
                        <footer>
                            <button string="Generate" name="generate_landoc_service" type="object" class="btn-primary"/>
                            <button string="Cancel" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="legal_service_process_act_window" model="ir.actions.act_window">
            <field name="name">Legal Service Process</field>
            <field name="res_model">legal.service.process</field>
            <field name="view_mode">form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    There is no examples click here to add new ModelTitle.
                </p>
            </field>
        </record>


    </data>
</odoo>
