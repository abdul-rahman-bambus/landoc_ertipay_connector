<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="custom_crm_res_partner_form_inherit" model="ir.ui.view">
            <field name="name">custom.crm.partner.form.inherit</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='mobile']" position="attributes">
                    <attribute name="placeholder">+91 9876543210</attribute>
                </xpath>

            </field>
        </record>
    </data>
</odoo>
