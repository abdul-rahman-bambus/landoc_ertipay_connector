<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!--  ########## Record Rules ######### -->

        <!--  ################################# -->
        <!--  ## Inheriting base record rule ## -->
        <!--  ################################# -->
        <function model="ir.model.data" name="write">
            <value model="ir.model.data"
                   search="[('module', '=', 'crm'), ('name', 'in', ['crm_rule_personal_lead', 'crm_rule_all_lead'])]"/>
            <value eval="{'noupdate': False}"/>
        </function>

        <!-- RULE: CRM Personal rule disabled -->
        <record id="crm.crm_rule_personal_lead" model="ir.rule">
            <field name="groups" eval="False"/>
            <field name="active" eval="False"/>
        </record>

        <!-- RULE: CRM All lead rule disabled -->
        <record id="crm.crm_rule_all_lead" model="ir.rule">
            <field name="groups" eval="False"/>
            <field name="active" eval="False"/>
        </record>

        <!-- ## ..... Ends here .......... ## -->


        <!--  ########################  -->
        <!--  ## Landoc Record Rule ##  -->
        <!--  ########################  -->

        <!-- RULE: CRM Normal User -->
        <record id="crm_lead_landoc_user_rule" model="ir.rule">
            <field name="name">Landoc CRM Normal User</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[
                        '&amp;',
                        ('company_id', 'in', user.company_ids.ids),
                        ('user_id', '=', user.id)
                    ]
            </field>
            <field name="groups" eval="[(4, ref('custom_landoc.group_landoc_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- RULE: CRM Team Lead User -->
        <record id="crm_landoc_team_lead_user_rule" model="ir.rule">
            <field name="name">Landoc CRM Team Lead User</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
             <field name="domain_force">
                [
                '&amp;',
                    ('company_id', 'in', user.company_ids.ids),
                    '|',

                        # CASE 1 → Team Lead → see team records
                        ('team_id.user_id', '=', user.id),

                        # CASE 2 → Not Team Lead → own + allowed departments
                        ('user_id', '=', user.id),
                ]
            </field>
            <field name="groups" eval="[(4, ref('custom_landoc.group_landoc_crm_team_lead_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

