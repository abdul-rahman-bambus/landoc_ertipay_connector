<odoo>
    <record id="view_partner_form_city_m2o" model="ir.ui.view">
        <field name="name">res.partner.form.city.m2o</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                    <field name="religion_id"/>
                </xpath>
            <xpath expr="//field[@name='city']" position="replace">
                <field name="city_id" placeholder="City" class="o_address_city" readonly="type == 'contact' and parent_id" options="{'no_open': False, 'no_create_edit': False}"/>
            </xpath>
        </field>
    </record>

    <record id="view_company_form_city_m2o" model="ir.ui.view">
        <field name="name">res.company.form.city.m2o</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='email']" position="after">
                    <field name="city" invisible="1"/>
                </xpath>
            <xpath expr="//field[@name='city']" position="replace">
                <field name="city_id" placeholder="City" class="o_address_city" options="{'no_open': False, 'no_create_edit': False}"/>
            </xpath>
        </field>
    </record>

    <record id="view_city_tree" model="ir.ui.view">
        <field name="name">res.city.list</field>
        <field name="model">res.city</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="state_id"/>
                <field name="country_id"/>
            </list>
        </field>
    </record>

    <record id="view_city_form" model="ir.ui.view">
        <field name="name">res.city.form</field>
        <field name="model">res.city</field>
        <field name="arch" type="xml">
            <form string="City">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="state_id"/>
                        <field name="country_id"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search: City -->
    <record id="res_city_search_view" model="ir.ui.view">
        <field name="name">res.city.search.view</field>
        <field name="model">res.city</field>
        <field name="arch" type="xml">
            <search string="City">
                <filter string="Tamil Nadu" name="tamil_nadu" domain="[('state_id.code', '=', 'TN')]"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="state" context="{'group_by':'state_id'}"/>
                    <filter string="Country" name="country" context="{'group_by':'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_res_city" model="ir.actions.act_window">
        <field name="name">Cities</field>
        <field name="res_model">res.city</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_res_city_root"
              name="Cities"
              parent="custom_landoc.master_data_main_menu"
              groups="custom_landoc.group_landoc_manager"
              action="action_res_city"/>
</odoo>
